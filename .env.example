# App URL (used for frontend links)
VITE_APP_URL=https://your-domain.com

# GitHub repository used for auto-resolving latest APK release.
GITHUB_REPO_OWNER=AleemKanyu
GITHUB_REPO_NAME=PocketCraft

# Optional GitHub token to avoid low unauthenticated rate limits.
GITHUB_TOKEN=

# Cache latest release metadata in milliseconds (default 5 minutes).
RELEASE_CACHE_TTL_MS=300000

# Optional static URL override (kept for emergency rollback only).
FORCE_STATIC_APK_URL=false
GITHUB_APK_URL=
VITE_APK_URL=

# Port (Hostinger will assign automatically, default: 3000)
PORT=3000
